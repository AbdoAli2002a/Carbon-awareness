rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Validation
    function isValidCommunityPost(data) {
      return data.keys().hasAll(['author', 'authorId', 'title', 'content', 'type', 'upvotes', 'createdAt', 'updatedAt', 'date', 'tags']) &&
             data.keys().size() == 10 &&
             data.author is string && data.author.size() <= 100 &&
             data.authorId == request.auth.uid &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 2000 &&
             data.type in ['قصة نجاح', 'فكرة مبتكرة'] &&
             data.upvotes is number &&
             data.createdAt is number &&
             data.updatedAt is number &&
             data.date is string &&
             data.tags is list && data.tags.size() <= 5;
    }

    function isValidVote(data) {
      return data.keys().hasAll(['userId', 'value']) &&
             data.keys().size() == 2 &&
             data.userId == request.auth.uid &&
             data.value in [1, -1];
    }

    // Posts Collection
    match /posts/{postId} {
      allow read: if true; // Public read
      allow create: if isVerified() && 
                    isValidId(postId) && 
                    isValidCommunityPost(incoming()) && 
                    incoming().createdAt == request.time.toMillis() &&
                    incoming().updatedAt == request.time.toMillis() &&
                    incoming().upvotes == 0;
                    
      allow update: if isVerified() && 
                    isValidId(postId) && (
                      // Action: Update own post
                      (existing().authorId == request.auth.uid && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'type', 'updatedAt', 'tags']) &&
                       incoming().title is string && incoming().title.size() <= 200 &&
                       incoming().content is string && incoming().content.size() <= 2000 &&
                       incoming().type in ['قصة نجاح', 'فكرة مبتكرة'] &&
                       incoming().tags is list && incoming().tags.size() <= 5 &&
                       incoming().updatedAt == request.time.toMillis()) 
                      ||
                      // Action: Update upvotes (anyone verified)
                      (incoming().diff(existing()).affectedKeys().hasOnly(['upvotes', 'updatedAt']) &&
                       incoming().upvotes is number &&
                       incoming().updatedAt == request.time.toMillis())
                    );
                    
      allow delete: if isVerified() && isValidId(postId) && existing().authorId == request.auth.uid;

      // Votes Subcollection
      match /votes/{voteId} {
        // voteId MUST be the userId of the voter
        allow read: if true; // To allow checking if a user has voted
        allow create: if isVerified() && 
                      voteId == request.auth.uid && 
                      isValidVote(incoming());
        allow update: if isVerified() && 
                      voteId == request.auth.uid && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['value']) &&
                      incoming().value in [1, -1];
        allow delete: if isVerified() && voteId == request.auth.uid;
      }
    }
  }
}
